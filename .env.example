# === Database ===
DB_HOST=host.docker.internal
DB_PORT=3306
DB_NAME=slim_service_db
DB_USER=root
DB_PASS=root

# === Environment ===
APP_ENV=local
APP_DEBUG=true

# === Service Metadata ===
SERVICE_NAME=slim-service-template
SERVICE_VERSION=1.0.0

# === CORS ===
ENABLE_CORS=true
CORS_ALLOW_ORIGIN_PATTERN=^https://([a-z0-9-]+\.)*example\.com$
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,Accept

# === Auth service communication ===
AUTH_SERVICE_URL=http://auth-service:8080
SERVICE_NAME=time-service        # eller auth-service, group-service etc