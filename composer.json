{
  "name": "template/slim-service",
  "description": "User management backend service",
  "license": "proprietary",
  "type": "project",  
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "infection/extension-installer": true, 
      "phpro/grumphp":true
    }
  },
  "require": {
    "php": "^8.3",
    "slim/slim": "^4.0",
    "php-di/php-di": "^7.0",
    "slim/psr7": "^1.5",
    "doctrine/dbal": "^3.6",
    "robmorgan/phinx": "^0.15.0",
    "monolog/monolog": "^3.0",
    "vlucas/phpdotenv": "^5.5",
    "ramsey/uuid": "^4.9"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "phpstan/phpstan": "^1.10",
    "squizlabs/php_codesniffer": "^3.7",
    "friendsofphp/php-cs-fixer": "^3.0",
    "infection/infection": "^0.27.0",
    "rector/rector": "^1.0",
    "phpro/grumphp": "^1.20"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "scripts": {
    "post-install-cmd": [
      "@php -r \"if (!is_dir('.ci')) mkdir('.ci', 0777, true); if (!file_exists('.ci/php-service')) touch('.ci/php-service'); if (!file_exists('.ci/dockerdeploy')) touch('.ci/dockerdeploy');\""
    ],
    "up": "docker compose up --build",
    "down": "docker compose down",
    "start": "docker compose up",
    "shell": "docker compose exec slim-service sh",
    "logs": "docker compose logs -f",
    "test": "docker compose exec slim-service vendor/bin/phpunit",
    "stan": "docker compose exec slim-service vendor/bin/phpstan analyse src --level=max",
    "fix": "docker compose exec slim-service vendor/bin/php-cs-fixer fix",
    "migrate": "docker compose exec slim-service vendor/bin/phinx migrate",
    "rollback": "docker compose exec slim-service vendor/bin/phinx rollback"
  }
}
